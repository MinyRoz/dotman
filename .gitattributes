# Normalize line endings deterministically across machines.
* text=auto eol=lf

# Shell scripts must always be LF, even when checked out on Windows,
# or bash on Linux/macOS will fail on carriage returns.
*.sh        text eol=lf
bin/dotman  text eol=lf

# Windows-native scripts use CRLF.
*.ps1       text eol=crlf
*.bat       text eol=crlf
*.cmd       text eol=crlf

# Treat these as binary (no EOL munging).
*.png binary
*.jpg binary
*.gif binary
