#!/usr/bin/env bash
#
# dotman — a portable, dependency-free dotfiles manager.
# Works on Linux, macOS, WSL, and Git Bash / MSYS on Windows.
#
# Usage: dotman <command> [options]
# Run `dotman help` for details.

set -euo pipefail

DOTMAN_VERSION="1.0.0"

# ---------------------------------------------------------------------------
# Resolve repository root (the directory that contains this script's parent).
# ---------------------------------------------------------------------------
_resolve_root() {
  local src="${BASH_SOURCE[0]}"
  while [ -h "$src" ]; do
    local dir
    dir="$(cd -P "$(dirname "$src")" >/dev/null 2>&1 && pwd)"
    src="$(readlink "$src")"
    [[ $src != /* ]] && src="$dir/$src"
  done
  cd -P "$(dirname "$src")/.." >/dev/null 2>&1 && pwd
}

DOTFILES_ROOT="${DOTFILES_ROOT:-$(_resolve_root)}"
CONFIG_FILE="${DOTMAN_CONFIG:-$DOTFILES_ROOT/dotman.conf}"
BACKUP_DIR="${DOTMAN_BACKUP_DIR:-$HOME/.dotman-backups/$(date +%Y%m%d-%H%M%S)}"

# ---------------------------------------------------------------------------
# Pretty output
# ---------------------------------------------------------------------------
if [ -t 1 ] && [ -z "${NO_COLOR:-}" ]; then
  C_RESET=$'\033[0m'; C_BOLD=$'\033[1m'; C_DIM=$'\033[2m'
  C_RED=$'\033[31m'; C_GREEN=$'\033[32m'; C_YELLOW=$'\033[33m'; C_BLUE=$'\033[34m'
else
  C_RESET=''; C_BOLD=''; C_DIM=''; C_RED=''; C_GREEN=''; C_YELLOW=''; C_BLUE=''
fi

info()  { printf '%s•%s %s\n' "$C_BLUE" "$C_RESET" "$*"; }
ok()    { printf '%s✓%s %s\n' "$C_GREEN" "$C_RESET" "$*"; }
warn()  { printf '%s!%s %s\n' "$C_YELLOW" "$C_RESET" "$*" >&2; }
err()   { printf '%s✗%s %s\n' "$C_RED" "$C_RESET" "$*" >&2; }
die()   { err "$*"; exit 1; }
header(){ printf '\n%s%s%s\n' "$C_BOLD" "$*" "$C_RESET"; }

DRY_RUN=0
FORCE=0

# ---------------------------------------------------------------------------
# OS detection
# ---------------------------------------------------------------------------
detect_os() {
  case "$(uname -s)" in
    Linux*)   [ -f /proc/version ] && grep -qiE 'microsoft|wsl' /proc/version && echo "wsl" || echo "linux" ;;
    Darwin*)  echo "macos" ;;
    CYGWIN*|MINGW*|MSYS*) echo "windows" ;;
    *)        echo "unknown" ;;
  esac
}
OS="$(detect_os)"

# ---------------------------------------------------------------------------
# Path expansion: ~ and ${VAR}
# ---------------------------------------------------------------------------
expand_path() {
  local p="$1"
  if [ "$p" = "~" ]; then
    p="$HOME"
  elif [ "${p#\~/}" != "$p" ]; then
    p="$HOME/${p#\~/}"
  fi
  # Expand ${VAR} / $VAR without eval (safe against injection, tolerates unset).
  while [[ "$p" =~ (\$\{?([A-Za-z_][A-Za-z0-9_]*)\}?) ]]; do
    local whole="${BASH_REMATCH[1]}" name="${BASH_REMATCH[2]}" val
    val="${!name:-}"
    p="${p//"$whole"/$val}"
  done
  printf '%s' "$p"
}

# ---------------------------------------------------------------------------
# Manifest parser
#
# Emits records on stdout for the requested section, one per line.
# Section matching: a base section (e.g. "link") plus its OS-specialised
# variants ("link.linux", "link.macos", etc.) for the current OS.
# ---------------------------------------------------------------------------
parse_section() {
  local want="$1"
  [ -f "$CONFIG_FILE" ] || die "Config not found: $CONFIG_FILE"
  awk -v want="$want" -v os="$OS" '
    function trim(s){ sub(/^[ \t]+/,"",s); sub(/[ \t]+$/,"",s); return s }
    /^[ \t]*#/ { next }
    /^[ \t]*$/ { next }
    /^\[.*\]$/ {
      sec=$0; gsub(/^\[|\]$/,"",sec); sec=trim(sec)
      active = (sec==want || sec==want"."os)
      next
    }
    active { print }
  ' "$CONFIG_FILE"
}

# ---------------------------------------------------------------------------
# Linking
# ---------------------------------------------------------------------------
backup_existing() {
  local dest="$1"
  if [ -e "$dest" ] || [ -L "$dest" ]; then
    if [ "$DRY_RUN" = 1 ]; then
      info "would back up $dest"
      return 0
    fi
    mkdir -p "$BACKUP_DIR"
    local name
    name="$(printf '%s' "$dest" | sed 's#[/\\]#_#g')"
    mv "$dest" "$BACKUP_DIR/$name"
    warn "backed up existing $dest -> $BACKUP_DIR/$name"
  fi
}

make_link() {
  local src="$1" dest="$2"
  [ -n "$dest" ] || { warn "empty destination (unresolved variable?), skipping: $src"; return 0; }
  [ -e "$src" ] || { warn "source missing, skipping: $src"; return 0; }
  mkdir -p "$(dirname "$dest")" 2>/dev/null || true

  # Already linked correctly?
  if [ -L "$dest" ] && [ "$(readlink "$dest")" = "$src" ]; then
    ok "linked (unchanged) ${C_DIM}$dest${C_RESET}"
    return 0
  fi

  if { [ -e "$dest" ] || [ -L "$dest" ]; } && [ "$FORCE" != 1 ]; then
    backup_existing "$dest"
  elif [ "$FORCE" = 1 ]; then
    [ "$DRY_RUN" = 1 ] || rm -rf "$dest"
  fi

  if [ "$DRY_RUN" = 1 ]; then
    info "would link $dest -> $src"
    return 0
  fi

  if ln -s "$src" "$dest" 2>/dev/null; then
    ok "linked $dest ${C_DIM}->${C_RESET} $src"
  else
    # Fallback for systems without symlink privileges (e.g. plain Windows).
    cp -R "$src" "$dest"
    warn "copied (symlink unavailable) $dest"
  fi
}

cmd_install() {
  header "dotman install ${C_DIM}($OS)${C_RESET}"
  run_hooks "hooks.pre"

  local count=0
  while IFS= read -r line; do
    [ -z "$line" ] && continue
    # shellcheck disable=SC2086
    set -- $line
    local src dest
    src="$DOTFILES_ROOT/$1"
    dest="$(expand_path "$2")"
    make_link "$src" "$dest"
    count=$((count + 1))
  done < <(parse_section "link")

  [ "$count" -eq 0 ] && warn "no [link] entries found in $CONFIG_FILE"

  install_packages
  run_hooks "hooks.post"
  header "${C_GREEN}Done.${C_RESET} ${C_DIM}Backups (if any) in $BACKUP_DIR${C_RESET}"
}

# ---------------------------------------------------------------------------
# Status
# ---------------------------------------------------------------------------
cmd_status() {
  header "dotman status ${C_DIM}($OS)${C_RESET}"
  while IFS= read -r line; do
    [ -z "$line" ] && continue
    # shellcheck disable=SC2086
    set -- $line
    local src dest
    src="$DOTFILES_ROOT/$1"
    dest="$(expand_path "$2")"
    [ -n "$dest" ] || continue
    if [ -L "$dest" ] && [ "$(readlink "$dest")" = "$src" ]; then
      ok "$dest"
    elif [ -e "$dest" ]; then
      warn "$dest ${C_DIM}(exists, not managed)${C_RESET}"
    else
      err "$dest ${C_DIM}(missing)${C_RESET}"
    fi
  done < <(parse_section "link")
}

# ---------------------------------------------------------------------------
# Unlink
# ---------------------------------------------------------------------------
cmd_unlink() {
  header "dotman unlink ${C_DIM}($OS)${C_RESET}"
  while IFS= read -r line; do
    [ -z "$line" ] && continue
    # shellcheck disable=SC2086
    set -- $line
    local src dest
    src="$DOTFILES_ROOT/$1"
    dest="$(expand_path "$2")"
    [ -n "$dest" ] || continue
    if [ -L "$dest" ] && [ "$(readlink "$dest")" = "$src" ]; then
      [ "$DRY_RUN" = 1 ] && { info "would remove $dest"; continue; }
      rm "$dest"; ok "removed $dest"
    fi
  done < <(parse_section "link")
}

# ---------------------------------------------------------------------------
# Packages
# ---------------------------------------------------------------------------
have() { command -v "$1" >/dev/null 2>&1; }

install_packages() {
  local section
  while IFS= read -r line; do
    [ -z "$line" ] && continue
    local mgr pkgs
    mgr="${line%%:*}"
    pkgs="$(printf '%s' "${line#*:}" | sed 's/^[ \t]*//')"
    [ -z "$pkgs" ] && continue
    have "$mgr" || { warn "package manager '$mgr' not found, skipping: $pkgs"; continue; }
    info "installing via $mgr: $pkgs"
    [ "$DRY_RUN" = 1 ] && continue
    # $pkgs is deliberately unquoted: it must split into separate package args.
    # shellcheck disable=SC2086
    case "$mgr" in
      brew)    brew install $pkgs ;;
      apt|apt-get) sudo apt-get update -y && sudo apt-get install -y $pkgs ;;
      dnf)     sudo dnf install -y $pkgs ;;
      pacman)  sudo pacman -S --noconfirm $pkgs ;;
      apk)     sudo apk add $pkgs ;;
      pkg)     sudo pkg install -y $pkgs ;;
      *)       $mgr install $pkgs ;;
    esac
  done < <(parse_section "packages")
}

# ---------------------------------------------------------------------------
# Hooks
# ---------------------------------------------------------------------------
run_hooks() {
  local section="$1"
  while IFS= read -r line; do
    [ -z "$line" ] && continue
    local script="$DOTFILES_ROOT/$line"
    [ -f "$script" ] || { warn "hook not found: $line"; continue; }
    info "hook: $line"
    [ "$DRY_RUN" = 1 ] && continue
    DOTFILES_ROOT="$DOTFILES_ROOT" OS="$OS" bash "$script"
  done < <(parse_section "$section")
}

# ---------------------------------------------------------------------------
# Doctor
# ---------------------------------------------------------------------------
cmd_doctor() {
  header "dotman doctor"
  info "version:       $DOTMAN_VERSION"
  info "os:            $OS ($(uname -srm))"
  info "repo root:     $DOTFILES_ROOT"
  info "config:        $CONFIG_FILE"
  if [ -f "$CONFIG_FILE" ]; then ok "config found"; else err "config missing"; fi
  info "home:          $HOME"
  for t in git ln awk sed; do
    if have "$t"; then ok "$t available"; else warn "$t missing"; fi
  done
}

# ---------------------------------------------------------------------------
# Help
# ---------------------------------------------------------------------------
cmd_help() {
  cat <<EOF
${C_BOLD}dotman${C_RESET} v$DOTMAN_VERSION — portable dotfiles manager

${C_BOLD}USAGE${C_RESET}
  dotman <command> [options]

${C_BOLD}COMMANDS${C_RESET}
  install     Symlink dotfiles, install packages, run hooks
  status      Show which managed files are linked / missing / unmanaged
  unlink      Remove symlinks created by dotman
  doctor      Print environment diagnostics
  version     Print version
  help        Show this help

${C_BOLD}OPTIONS${C_RESET}
  -n, --dry-run    Show what would happen without changing anything
  -f, --force      Replace existing files instead of backing them up
  -c, --config F   Use an alternate manifest (default: dotman.conf)

${C_BOLD}ENVIRONMENT${C_RESET}
  DOTFILES_ROOT     Override repository root
  DOTMAN_CONFIG     Override manifest path
  DOTMAN_BACKUP_DIR Override backup directory
  NO_COLOR          Disable coloured output

${C_BOLD}EXAMPLES${C_RESET}
  dotman install --dry-run
  dotman install
  dotman status
  DOTMAN_CONFIG=./work.conf dotman install
EOF
}

# ---------------------------------------------------------------------------
# Argument parsing
# ---------------------------------------------------------------------------
main() {
  local cmd="${1:-help}"; shift || true
  local args=()
  while [ $# -gt 0 ]; do
    case "$1" in
      -n|--dry-run) DRY_RUN=1 ;;
      -f|--force)   FORCE=1 ;;
      -c|--config)  CONFIG_FILE="$2"; shift ;;
      --config=*)   CONFIG_FILE="${1#*=}" ;;
      -h|--help)    cmd="help" ;;
      *)            args+=("$1") ;;
    esac
    shift
  done

  case "$cmd" in
    install|link)   cmd_install ;;
    status|ls)      cmd_status ;;
    unlink|remove)  cmd_unlink ;;
    doctor)         cmd_doctor ;;
    version|-v|--version) echo "dotman $DOTMAN_VERSION" ;;
    help|*)         cmd_help ;;
  esac
}

main "$@"
